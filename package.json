{
  "name": "socketio-chat-app",
  "version": "2.0.0",
  "description": "A polished multi-room chat application with Socket.IO, private messaging, typing indicators, and mobile support.",
  "main": "chat-server.js",
  "scripts": {
    "start": "node chat-server.js",
    "dev": "nodemon chat-server.js",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "chat",
    "socket.io",
    "realtime",
    "messaging"
  ],
  "dependencies": {
    "socket.io": "^4.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "*.{html,css,js,json,md}": "prettier --write"
  },
